{
  "name": "bmad-story-automator",
  "version": "1.14.1",
  "description": "Install the BMAD story-automator pure skill bundle into a BMAD project.",
  "license": "MIT",
  "bin": {
    "bmad-story-automator": "bin/bmad-story-automator"
  },
  "files": [
    "bin/",
    "docs/",
    "install.sh",
    "payload/",
    "README.md",
    "ref.png",
    "source/"
  ],
  "scripts": {
    "pack:dry-run": "npm pack --dry-run",
    "test:python": "PYTHONPATH=source/src python3 -m unittest discover -s source/tests",
    "test:smoke": "bash scripts/smoke-test.sh",
    "verify": "npm run test:python && npm run pack:dry-run && npm run test:smoke"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "bmad",
    "claude",
    "codex",
    "workflow",
    "automation",
    "python"
  ]
}
